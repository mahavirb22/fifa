# MatchDay Command Center — Environment Configuration
# Copy to .env and fill in your values.

# Google Cloud — credentials come from the runtime service account
# (Application Default Credentials). No API keys needed.
# Locally: run `gcloud auth application-default login`
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Feature flags — disable to run without cloud dependencies
USE_GEMINI=false
USE_FIRESTORE=false

# Gemini prompt version — selects prompts/v{N}.yaml
GEMINI_PROMPT_VERSION=1

# CORS — comma-separated origins allowed in development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting — storage URI for slowapi
RATE_LIMIT_STORAGE=memory://
